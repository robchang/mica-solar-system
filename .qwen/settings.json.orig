{
  "model": {
    "maxSessionTurns": 100,
    "generationConfig": {
      "contextWindowSize": 131072,
      "enableCacheControl": true,
      "samplingParams": {
        "temperature": 0.6,
        "top_p": 0.95,
        "top_k": 20,
        "min_p": 0.0,
        "presence_penalty": 0.0,
        "repetition_penalty": 1.0,
        "max_tokens": 6144
      },
      "extra_body": {
        "chat_template_kwargs": { "enable_thinking": true }
      }
    }
  },
  "tools": {
    "truncateToolOutputThreshold": 50000
  },
  "context": {
    "fileFiltering": {
      "enableFuzzySearch": false
    }
  },
  "mcpServers": {
    "tavily": {
      "command": "npx",
      "args": ["-y", "tavily-mcp"]
    }
  }
}
